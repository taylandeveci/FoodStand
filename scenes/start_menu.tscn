[gd_scene format=4]

[ext_resource type="Script" path="res://scripts/start_menu.gd" id="1_script"]
[ext_resource type="Texture2D" path="res://assets/props/props_titles/prop_foodstandtitle.png" id="2_title"]
[ext_resource type="Texture2D" path="res://assets/props/props_titles/prop_playbutton.png" id="3_play"]

[node name="StartMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 1
script = ExtResource("1_script")

[node name="CenterContainer" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="CenterContainer"]
layout_mode = 2
theme_override_constants/separation = 24
alignment = 1

[node name="TitleTexture" type="TextureRect" parent="CenterContainer/VBoxContainer"]
custom_minimum_size = Vector2(576, 384)
layout_mode = 2
texture = ExtResource("2_title")
expand_mode = 1
stretch_mode = 5

[node name="PlayButton" type="TextureButton" parent="CenterContainer/VBoxContainer"]
